<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <Console name="STDOUT" target="SYSTEM_ERR">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p %21.21c{1}:%-4L %m%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Logger name="tech.ydb.samples" level="info"/>
        <Logger name="com.zaxxer.hikari" level="warn"/>
        <Logger name="tech.ydb.query.impl" level="error"/>
        <Root level="warn">
            <AppenderRef ref="STDOUT"/>
        </Root>
    </Loggers>
</Configuration>
